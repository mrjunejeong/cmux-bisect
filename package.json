{
  "name": "cmux-bisect",
  "version": "0.1.0",
  "description": "git bisect for AI agent decisions — localize the first bad tool call in log₂(N) trials",
  "type": "module",
  "license": "MIT",
  "author": "June Jeong <mrjunejeong@gmail.com>",
  "homepage": "https://github.com/mrjunejeong/cmux-bisect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrjunejeong/cmux-bisect.git"
  },
  "bugs": {
    "url": "https://github.com/mrjunejeong/cmux-bisect/issues"
  },
  "keywords": [
    "ai-agents",
    "debugging",
